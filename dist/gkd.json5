    { key: 3, name: '青少年模式', enable: false },
    { key: 4, name: '快捷确认', enable: false },
  ],
  globalGroups: [
    {
      key: 0,
      name: '开屏广告-全局兜底跳过',
      desc: '进入应用后的短时间内点击明确“跳过”按钮。快照精准规则优先，本规则兜底。',
      categoryKey: 0,
      fastQuery: true,
      matchTime: 10000,
      forcedTime: 3000,
      priorityTime: 10000,
      actionMaximum: 1,
      resetMatch: 'app',
      actionCd: 1000,
      rules: [
        { key: 0, name: '精确文本：跳过', matches: '[text="跳过"][visibleToUser=true]' },
        { key: 1, name: '短文本：包含跳过', matches: '[text*="跳过"][text.length<8][visibleToUser=true]' },
        { key: 2, name: '描述：包含跳过', matches: '[desc*="跳过"][desc.length<12][visibleToUser=true]' },
        { key: 3, name: '英文 Skip', matches: '[text~="(?i)^skip[0-9 ]*$"][visibleToUser=true]' },
        { key: 4, name: '倒计时跳过', matches: '[text~="^.*[0-9]+(s|秒).*跳过.*$"][visibleToUser=true]' },
      ],
    },
    {
      key: 10,
      name: '弹窗处理-常见关闭按钮',
      desc: '默认关闭。用于活动、会员、福利、推荐类弹窗，启用前建议抓快照校准。',
      categoryKey: 1,
      enable: false,
      fastQuery: true,
      matchTime: 8000,
      actionMaximum: 2,
      resetMatch: 'activity',
      actionCd: 1200,
      rules: [
        { key: 0, name: '关闭', matches: '[text="关闭"][visibleToUser=true]' },
        { key: 1, name: '以后再说', matches: '[text="以后再说"][visibleToUser=true]' },
        { key: 2, name: '暂不', matches: '[text="暂不"][visibleToUser=true]' },
